{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/api/send": {
            "post": {
                "description": "Send text, photo, video, audio, or document using a registered device API key.\n\nAuthentication:\n- Header: X-Api-Key\n- Or query parameter: api_key",
                "consumes": [
                    "application/json",
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "API"
                ],
                "summary": "Send Telegram message",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Device API Key",
                        "name": "X-Api-Key",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Device API Key",
                        "name": "api_key",
                        "in": "query"
                    },
                    {
                        "description": "JSON Request",
                        "name": "request",
                        "in": "body",
                        "schema": {
                            "$ref": "#/definitions/handlers.apiSendMessageRequest"
                        }
                    },
                    {
                        "type": "string",
                        "description": "Target phone number",
                        "name": "phone",
                        "in": "formData"
                    },
                    {
                        "type": "string",
                        "description": "Telegram Chat ID",
                        "name": "chat_id",
                        "in": "formData"
                    },
                    {
                        "type": "string",
                        "description": "user, chat, channel",
                        "name": "peer_type",
                        "in": "formData"
                    },
                    {
                        "type": "integer",
                        "description": "Telegram access hash",
                        "name": "access_hash",
                        "in": "formData"
                    },
                    {
                        "type": "string",
                        "description": "Message text",
                        "name": "message",
                        "in": "formData"
                    },
                    {
                        "type": "string",
                        "description": "Media caption",
                        "name": "caption",
                        "in": "formData"
                    },
                    {
                        "type": "file",
                        "description": "Media file",
                        "name": "file",
                        "in": "formData"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handlers.apiSendMessageResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/handlers.apiErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/handlers.apiErrorResponse"
                        }
                    },
                    "422": {
                        "description": "Unprocessable Entity",
                        "schema": {
                            "$ref": "#/definitions/handlers.apiErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/handlers.apiErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handlers.apiErrorResponse": {
            "type": "object",
            "properties": {
                "detail": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "error": {
                    "type": "string"
                },
                "error_type": {
                    "type": "string"
                }
            }
        },
        "handlers.apiSendMessageRequest": {
            "type": "object",
            "properties": {
                "access_hash": {
                    "type": "integer",
                    "example": 0
                },
                "caption": {
                    "type": "string",
                    "example": "Photo Caption"
                },
                "chat_id": {
                    "type": "string",
                    "example": "123456789"
                },
                "media_base64": {
                    "type": "string"
                },
                "media_filename": {
                    "type": "string",
                    "example": "photo.jpg"
                },
                "media_url": {
                    "type": "string",
                    "example": "https://example.com/photo.jpg"
                },
                "message": {
                    "type": "string",
                    "example": "Hello World"
                },
                "peer_type": {
                    "type": "string",
                    "example": "user"
                },
                "phone": {
                    "type": "string",
                    "example": "6281234567890"
                }
            }
        },
        "handlers.apiSendMessageResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "Message sent"
                }
            }
        }
    }
}