# Dapatkan dari https://my.telegram.org
APP_ID=12345678
APP_HASH=your_api_hash_here

# Server
ADDR=:8000
APP_URL=http://localhost:8000

# MySQL DSN
MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/telegram_sender?charset=utf8mb4&parseTime=True&loc=Local

# Session cookie key (ubah di production)
COOKIE_KEY=change-me-in-production
